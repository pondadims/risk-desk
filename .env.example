# ─── Storage mode ────────────────────────────────────────────
# "local"  → journal saved in the browser localStorage (no backend needed)  [default]
# "api"    → journal + account saved in Postgres via /api serverless functions
VITE_STORAGE=local

# ─── Database (required when VITE_STORAGE=api) ────────────────
# Get a free Postgres URL from https://neon.tech
# Then run: npm run db:init   (creates tables + seeds account row)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
